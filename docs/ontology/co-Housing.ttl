#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Característica
                :Infraestructura
                :Persona
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Alvaro
                        :Eva
                        :Juan
                      )
] .


